# ============================================================
# config.local.ini —— 本地敏感覆盖，【严禁入仓】（.gitignore 的 *.local.ini 已忽略）。
# 复制为 config.local.ini 后填写。ci_config.load() 会自动叠加覆盖 config.ini。
# 只放敏感项：Jenkins admin 密码。等效环境变量优先：JENKINS_ADMIN_PASSWORD。
#
# 含明文密码的下载代理放本文件 [proxy]（config.ini [proxy] 只留空模板，不入仓 C-1）；
# fetch_plugins.py 读 [proxy] 注入 curl。
# ============================================================

[proxy]
# 含密码的代理写这里（覆盖 config.ini 的空值）；不需要代理就整段删掉/留空。
# curl 仅认小写 http_proxy；https/all/no 大小写都认，脚本会补齐。
https_proxy = http://user:pass@proxy.corp:8080
http_proxy = http://user:pass@proxy.corp:8080
all_proxy =
no_proxy = .corp,localhost,127.0.0.1

[secrets]
# Jenkins admin 密码：JCasC 建 admin 用户用（等效 env JENKINS_ADMIN_PASSWORD）。
# 部署时 deploy.py 写入 systemd EnvironmentFile（0600）。
jenkins_admin_password = change-me
