{
  "$schema": "https://opencode.ai/config.json",
  "_comment": "Jenkins 官方 mcp-server 插件的 MCP 端点（D-016，无自写 MCP）。服务端搭建 + API token 生成见 local/mcp/README.md。",
  "_auth": "Authorization = Basic base64(admin:API_TOKEN)；admin=config.ini [jenkins] admin_user，token 在 Jenkins UI 头像→Security→API Token 生成。端点 /mcp-server/mcp（Streamable HTTP）。",
  "mcp": {
    "jenkins": {
      "type": "remote",
      "url": "http://<jenkins-host>:8080/mcp-server/mcp",
      "enabled": true,
      "headers": {
        "Authorization": "Basic <base64(admin:API_TOKEN)>"
      }
    }
  }
}
